{
  "name": "@repo/api",
  "version": "1.0.0",
  "description": "Agent-first NestJS API starter kit (Fastify + Prisma + Passport/JWT + provider-agnostic AI)",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "check": "npm run lint:check && npm run typecheck",
    "test": "bun test src",
    "test:watch": "bun test --watch src",
    "test:cov": "bun test --coverage src",
    "test:e2e": "bun test test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "dev": "nest start --watch",
    "postinstall": "prisma generate || echo \"prisma generate skipped (run it after setting up .env)\""
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.27",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8",
    "@repo/shared": "*",
    "@prisma/adapter-pg": "^7.8.0",
    "pg": "^8.22.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.8",
    "@nestjs/testing": "^11.1.27",
    "@types/node": "^26.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "@repo/config": "*",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "pino-pretty": "^13.1.3"
  }
}
