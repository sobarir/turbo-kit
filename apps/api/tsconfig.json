{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "bun",
      "node"
    ],
    "paths": {
      "src/*": [
        "src/*"
      ],
      "@repo/shared": [
        "../../packages/shared/src"
      ]
    },
    "baseUrl": "./",
    "ignoreDeprecations": "6.0",
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "prisma/**/*",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/generated/**"
  ]
}
